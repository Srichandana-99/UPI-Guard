# Production Environment Configuration
# DATABASE_URL will be set by Render
# SENDER_EMAIL and SENDER_PASSWORD will be set by Render

# Email Configuration (for OTP)
SENDER_EMAIL=upiguard.demo@gmail.com
SENDER_PASSWORD=your-app-password-here

# Admin Emails (for admin access)
ADMIN_EMAILS=admin@upiguard.com,security@upiguard.com

# CORS Origins (for frontend)
CORS_ORIGINS=https://your-app.vercel.app
